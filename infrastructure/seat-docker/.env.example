PROXY_BACKEND_HTTP_PORT=8080
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_ACME_EMAIL=you@example.com
SEAT_DOMAIN=seat.example.com
APP_DEBUG=false
LOG_LEVEL=error
APP_URL=https://${SEAT_DOMAIN}
APP_KEY=REPLACE_WITH_SEAT_APP_KEY
APP_LOCALE=en
APP_ENV=production
XDG_CONFIG_HOME=/tmp
DB_CONNECTION=mysql
DB_DATABASE=seat
DB_USERNAME=seat
DB_HOST=mariadb
DB_PORT=3306
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
REDIS_HOST=cache
REDIS_PORT=6379
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@localhost.local
MAIL_FROM_NAME='SeAT Administrator'
EVE_CLIENT_ID=REPLACE_WITH_EVE_CLIENT_ID
EVE_CLIENT_SECRET=REPLACE_WITH_EVE_CLIENT_SECRET
EVE_CALLBACK_URL=${APP_URL}/auth/eve/callback
ESEYE_CACHE_DRIVER=file
ESEYE_CACHE_STORAGE_PATH=eseye
ESEYE_CACHE_CONNECTION=cache
ESEYE_CACHE_LOCK_CONNECTION=default
