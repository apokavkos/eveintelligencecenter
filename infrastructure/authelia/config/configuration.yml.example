theme: dark
jwt_secret: "REPLACE_WITH_64_CHAR_SECRET"
default_2fa_method: totp

server:
  host: 0.0.0.0
  port: 9091

log:
  level: info

totp:
  issuer: sso.example.com

notifier:
  filesystem:
    filename: /config/notification.txt

authentication_backend:
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id

access_control:
  default_policy: deny
  rules:
    - domain:
        - "sso.example.com"
      policy: bypass

session:
  secret: "REPLACE_WITH_64_CHAR_SECRET"
  cookies:
    - domain: "example.com"
      authelia_url: "https://sso.example.com"
      default_redirection_url: "https://app.example.com"

storage:
  encryption_key: "REPLACE_WITH_64_CHAR_SECRET"
  local:
    path: /config/db.sqlite3

identity_providers:
  oidc:
    hmac_secret: "REPLACE_WITH_64_CHAR_SECRET"
    issuer_private_key: |
      -----BEGIN RSA PRIVATE KEY-----
      REPLACE_WITH_PRIVATE_KEY_PEM
      -----END RSA PRIVATE KEY-----
    clients:
      - id: claude-ai-mcp
        description: Claude.ai MCP Connector
        secret: "$pbkdf2-sha512$REPLACE_WITH_HASH"
        public: false
        authorization_policy: two_factor
        redirect_uris:
          - "https://claude.ai/oauth/callback"
        scopes:
          - openid
          - profile
          - email
        consent_mode: pre-configured
